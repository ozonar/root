APP_ENV=dev
APP_SECRET=dev-secret-key-change-in-production
APP_DEBUG=1

# PostgreSQL
DATABASE_URL="postgresql://symfony:symfony@127.0.0.1:5432/task_manager?serverVersion=15&charset=utf8"

# Mailer
MAILER_DSN=smtp://localhost:1025
MAILER_ADAPTER=file

# Unisender
UNISENDER_API_KEY=

# Web Push (VAPID)
# Сгенерируйте ключи командой: php bin/console app:generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@checker.app