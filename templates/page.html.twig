{% extends 'base.html.twig' %}

{% block title %}Checker — Редактор{% endblock %}

{% block body %}
<div id="app">
    <!-- Header -->
    <header class="header">
        <div class="header-left">
            <a href="/" class="btn btn-sm btn-outline" id="back-to-main">
                <i class="fas fa-arrow-left"></i> Назад
            </a>
        </div>
        <div class="header-center">
            <h2 id="full-page-title" contenteditable="true" class="page-title-editable"></h2>
        </div>
        <div class="header-right">
            <button id="add-task-btn" class="btn btn-sm btn-primary" title="Добавить задачу">
                <i class="fas fa-plus"></i> Задача
            </button>
            <button id="delete-page-btn" class="btn btn-sm btn-outline btn-danger-outline" title="Удалить страницу">
                <i class="fas fa-trash"></i>
            </button>
        </div>
    </header>

    <!-- Editor Body -->
    <main class="main-content">
        <div class="tasks-container" id="tasks-container"></div>
    </main>
</div>

<!-- Task Modal -->
<div class="modal-overlay" id="task-modal" style="display: none;">
    <div class="modal">
        <div class="modal-header">
            <h3 id="modal-title">Редактирование задачи</h3>
            <button class="modal-close" id="modal-close">&times;</button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label>Текст задачи</label>
                <div id="modal-task-text" contenteditable="true" class="modal-editable"></div>
            </div>
            <div class="form-group">
                <label>Описание</label>
                <textarea id="modal-task-description" class="modal-textarea" rows="4"></textarea>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Статус</label>
                    <div class="custom-select-wrapper" id="modal-status-wrapper">
                        <div class="custom-select-trigger" id="modal-status-trigger">
                            <span class="custom-select-trigger-text"></span>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="custom-select-dropdown" id="modal-status-dropdown"></div>
                        <select id="modal-task-status" style="display:none"></select>
                    </div>
                </div>
                <div class="form-group">
                    <label>Приоритет</label>
                    <label class="checkbox-label">
                        <input type="checkbox" id="modal-task-priority">
                        Высокий приоритет
                    </label>
                </div>
            </div>
            <div class="form-group">
                <label>Ответственный</label>
                <select id="modal-task-assignee" class="form-select">
                    <option value="">Без исполнителя</option>
                </select>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" id="modal-cancel">Отмена</button>
            <button class="btn btn-primary" id="modal-save">Сохранить</button>
        </div>
    </div>
</div>

{% include '_context_menus.html.twig' %}
{% endblock %}

{% block javascripts %}
{% include '_init_scripts.html.twig' %}
<script>
const PAGE_ID = {{ pageId }};

// ==========================================
// Init
// ==========================================

document.addEventListener('DOMContentLoaded', function() {
    const token = localStorage.getItem('auth_token');
    if (!token) {
        window.location.href = '/login';
        return;
    }

    loadPage();

    document.getElementById('add-task-btn').addEventListener('click', function() {
        addNewTask(PAGE_ID);
    });

    // Load project users for assignee menu
    apiRequest('/me').then(function(meResponse) {
        var projectId = meResponse.user.currentProjectId;
        if (projectId) {
            currentProjectId = projectId;
            loadProjectUsers(projectId);
        }
    });

    // Delete page button
    document.getElementById('delete-page-btn').addEventListener('click', function(e) {
        e.stopPropagation();
        if (!confirm('Вы уверены, что хотите удалить эту страницу?')) return;
        apiRequest('/pages/' + PAGE_ID, 'DELETE').then(function() {
            window.location.href = '/';
        }).catch(function(err) {
            console.error('Failed to delete page:', err);
            alert('Не удалось удалить страницу. Возможно, у вас нет доступа.');
        });
    });

    // Auto-save page title on input
    document.addEventListener('input', function(e) {
        if (e.target.id === 'full-page-title') {
            var title = e.target.textContent.trim();
            if (title) {
                debouncedSave('page-title', function() {
                    apiRequest('/pages/' + PAGE_ID, 'PUT', { title: title });
                });
            }
        }
    });
});

// ==========================================
// Page Loading
// ==========================================

function loadPage() {
    apiRequest('/pages/' + PAGE_ID).then(function(response) {
        document.getElementById('full-page-title').textContent = response.page.title;
        statuses = response.statuses || [];
        renderInlineTasks(response.tasks || [], document.getElementById('tasks-container'), PAGE_ID);
    }).catch(function(xhr) {
        console.error('Failed to load page:', xhr);
        if (xhr.status === 401) {
            localStorage.removeItem('auth_token');
            window.location.href = '/login';
        } else if (xhr.status === 404) {
            document.getElementById('tasks-container').innerHTML = '<div class="text-muted" style="text-align:center;padding:40px;">Страница не найдена</div>';
        }
    });
}

window.reloadTasks = function(pageId, tasks) {
    statuses = statuses;
    renderInlineTasks(tasks || [], document.getElementById('tasks-container'), PAGE_ID);
};
</script>
{% endblock %}