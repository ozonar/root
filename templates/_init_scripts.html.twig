<script>
// ==========================================
// Shared initialization for context menus and modals
// ==========================================

document.addEventListener('DOMContentLoaded', function() {
    // Hide all context menus on any click (except burger menu and its trigger)
    document.addEventListener('click', function(e) {
        var target = e.target;
        if (target.closest('.context-menu') || target.closest('.burger-btn')) {
            return;
        }
        hideAllContextMenus();
    });

    // Close context menus on escape
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            hideAllContextMenus();
        }
    });

    // New status modal handlers
    var newStatusClose = document.getElementById('new-status-modal-close');
    if (newStatusClose) {
        newStatusClose.addEventListener('click', function() {
            closeNewStatusModal();
        });
    }
    var newStatusCancel = document.getElementById('new-status-modal-cancel');
    if (newStatusCancel) {
        newStatusCancel.addEventListener('click', function() {
            closeNewStatusModal();
        });
    }
    var newStatusSave = document.getElementById('new-status-modal-save');
    if (newStatusSave) {
        newStatusSave.addEventListener('click', function() {
            confirmNewStatus();
        });
    }
    var newStatusInput = document.getElementById('new-status-name-input');
    if (newStatusInput) {
        newStatusInput.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                confirmNewStatus();
            }
        });
    }

    // Custom select dropdown toggle
    document.addEventListener('click', function(e) {
        var trigger = document.getElementById('modal-status-trigger');
        var dropdown = document.getElementById('modal-status-dropdown');
        if (!trigger || !dropdown) return;

        if (trigger.contains(e.target)) {
            e.stopPropagation();
            dropdown.classList.toggle('open');
            trigger.classList.toggle('open');
        } else if (!dropdown.contains(e.target)) {
            dropdown.classList.remove('open');
            trigger.classList.remove('open');
        }
    });

    // Modal handlers
    var modalClose = document.getElementById('modal-close');
    if (modalClose) {
        modalClose.addEventListener('click', function() {
            closeModal();
        });
    }
    var modalCancel = document.getElementById('modal-cancel');
    if (modalCancel) {
        modalCancel.addEventListener('click', function() {
            closeModal();
        });
    }
    var modalSave = document.getElementById('modal-save');
    if (modalSave) {
        modalSave.addEventListener('click', function() {
            saveTaskFromModal();
        });
    }
    // Page settings menu handlers
    var pageSettingsSave = document.getElementById('page-settings-save');
    if (pageSettingsSave) {
        pageSettingsSave.addEventListener('click', function(e) {
            e.stopPropagation();
            savePageTitle();
        });
    }

    var pageSettingsDelete = document.getElementById('page-settings-delete');
    if (pageSettingsDelete) {
        pageSettingsDelete.addEventListener('click', function(e) {
            e.stopPropagation();
            deletePage();
        });
    }

    var pageSettingsInput = document.getElementById('page-settings-title-input');
    if (pageSettingsInput) {
        pageSettingsInput.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                e.stopPropagation();
                savePageTitle();
            }
        });
    }

    // Burger button click handler (delegated for dynamically created cards)
    document.addEventListener('click', function(e) {
        var burgerBtn = e.target.closest('.burger-btn');
        if (burgerBtn) {
            e.stopPropagation();
            e.preventDefault();
            var pageId = parseInt(burgerBtn.dataset.pageId);
            var pageTitle = burgerBtn.dataset.pageTitle || '';
            showPageSettingsMenu(e.pageX, e.pageY, pageId, pageTitle);
        }
    });

    // User name edit menu handlers
    var userNameEl = document.getElementById('user-name');
    if (userNameEl) {
        userNameEl.addEventListener('click', function(e) {
            e.stopPropagation();
            var currentName = this.textContent || '';
            showUserNameMenu(e.pageX, e.pageY, currentName);
        });
    }

    var usernameSaveBtn = document.getElementById('username-edit-save');
    if (usernameSaveBtn) {
        usernameSaveBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            saveUserName();
        });
    }

    var usernameInput = document.getElementById('username-edit-input');
    if (usernameInput) {
        usernameInput.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                e.stopPropagation();
                saveUserName();
            }
        });
    }
    // Project Settings Modal handlers
    var projectSettingsBtn = document.getElementById('project-settings-btn');
    if (projectSettingsBtn) {
        projectSettingsBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            openProjectSettingsModal();
        });
    }

    var projectSettingsClose = document.getElementById('project-settings-modal-close');
    if (projectSettingsClose) {
        projectSettingsClose.addEventListener('click', function() {
            closeProjectSettingsModal();
        });
    }

    var projectSettingsCancel = document.getElementById('project-settings-modal-cancel');
    if (projectSettingsCancel) {
        projectSettingsCancel.addEventListener('click', function() {
            closeProjectSettingsModal();
        });
    }

    // Close on overlay click
    var projectSettingsModal = document.getElementById('project-settings-modal');
    if (projectSettingsModal) {
        projectSettingsModal.addEventListener('click', function(e) {
            if (e.target === this) {
                closeProjectSettingsModal();
            }
        });
    }

    // Tabs
    var tabs = document.querySelectorAll('#project-settings-tabs .tab');
    tabs.forEach(function(tab) {
        tab.addEventListener('click', function() {
            // Deactivate all tabs
            tabs.forEach(function(t) { t.classList.remove('active'); });
            this.classList.add('active');

            // Hide all tab contents
            var tabContents = document.querySelectorAll('#project-settings-modal .tab-content');
            tabContents.forEach(function(tc) { tc.classList.remove('active'); });

            // Show selected tab
            var target = document.getElementById('tab-' + this.dataset.tab);
            if (target) {
                target.classList.add('active');
            }
        });
    });

    // Invite user
    var inviteBtn = document.getElementById('invite-user-btn');
    if (inviteBtn) {
        inviteBtn.addEventListener('click', function() {
            inviteUser();
        });
    }

    var inviteEmailInput = document.getElementById('invite-user-email');
    if (inviteEmailInput) {
        inviteEmailInput.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                inviteUser();
            }
        });
    }

    // Rename project
    var renameBtn = document.getElementById('rename-project-btn');
    if (renameBtn) {
        renameBtn.addEventListener('click', function() {
            renameProject();
        });
    }

    var renameInput = document.getElementById('rename-project-input');
    if (renameInput) {
        renameInput.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                renameProject();
            }
        });
    }

    // Add status from settings
    var addStatusBtn = document.getElementById('settings-add-status-btn');
    if (addStatusBtn) {
        addStatusBtn.addEventListener('click', function() {
            addStatusFromSettings();
        });
    }

    var newStatusNameInput = document.getElementById('new-status-name-input');
    if (newStatusNameInput) {
        newStatusNameInput.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                addStatusFromSettings();
            }
        });
    }
});
</script>