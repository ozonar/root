{% extends 'base.html.twig' %}

{% block title %}Root{% endblock %}

{% block body %}
<div id="app">
    <!-- Header -->
    <header class="header">
        <div class="header-left">
            <a href="/" class="header-title">Root</a>
        </div>
        <div class="header-center">
            <select id="project-selector" class="project-selector">
            </select>
            <button id="project-settings-btn" class="btn btn-sm btn-outline project-settings-btn" title="Настройки проекта">
                <i class="fas fa-cog"></i>
            </button>
        </div>
        <div class="header-right">
            <span id="user-name" class="user-name"></span>
            <button id="logout-btn" class="btn btn-sm btn-outline" title="Выйти">
                <i class="fas fa-sign-out-alt"></i>
            </button>
        </div>
    </header>

    <!-- Main Content -->
    <main class="main-content">
        <div class="pages-grid" id="pages-grid">
            <div class="loading-pages">Загрузка...</div>
        </div>
        <div class="new-page-bottom">
            <button id="new-page-btn" class="btn btn-primary" title="Новая страница">
                <i class="fas fa-plus"></i> Страница
            </button>
        </div>
    </main>
</div>

<!-- Task Modal -->
<div class="modal-overlay" id="task-modal" style="display: none;">
    <div class="modal">
        <div class="modal-header">
            <h3 id="modal-title">Редактирование задачи</h3>
            <button class="modal-close" id="modal-close">&times;</button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label>Текст задачи</label>
                <div id="modal-task-text" contenteditable="true" class="modal-editable"></div>
            </div>
            <div class="form-group">
                <label>Описание</label>
                <textarea id="modal-task-description" class="modal-textarea" rows="4"></textarea>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Статус</label>
                    <div class="custom-select-wrapper" id="modal-status-wrapper">
                        <div class="custom-select-trigger" id="modal-status-trigger">
                            <span class="custom-select-trigger-text"></span>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="custom-select-dropdown" id="modal-status-dropdown"></div>
                        <select id="modal-task-status" style="display:none"></select>
                    </div>
                </div>
                <div class="form-group">
                    <label>Приоритет</label>
                    <label class="checkbox-label">
                        <input type="checkbox" id="modal-task-priority">
                        Высокий приоритет
                    </label>
                </div>
            </div>
            <div class="form-group">
                <label>Ответственный</label>
                <select id="modal-task-assignee" class="form-select">
                    <option value="">Без исполнителя</option>
                </select>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" id="modal-cancel">Отмена</button>
            <button class="btn btn-primary" id="modal-save">Сохранить</button>
        </div>
    </div>
</div>

<!-- New Page Modal -->
<div class="modal-overlay" id="new-page-modal" style="display: none;">
    <div class="modal modal-sm">
        <div class="modal-header">
            <h3>Новая страница</h3>
            <button class="modal-close" id="new-page-modal-close">&times;</button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label>Название страницы</label>
                <input type="text" id="new-page-title-input" class="form-input" placeholder="Введите название..." autofocus>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" id="new-page-modal-cancel">Отмена</button>
            <button class="btn btn-primary" id="new-page-modal-save">Создать</button>
        </div>
    </div>
</div>

<!-- Project Settings Modal -->
<div class="modal-overlay" id="project-settings-modal" style="display: none;">
    <div class="modal modal-lg">
        <div class="modal-header">
            <h3>Настройки проекта</h3>
            <button class="modal-close" id="project-settings-modal-close">&times;</button>
        </div>
        <div class="modal-body">
            <!-- Tabs -->
            <div class="tabs" id="project-settings-tabs">
                <button class="tab active" data-tab="users">Пользователи</button>
                <button class="tab" data-tab="rename">Переименовать</button>
                <button class="tab" data-tab="statuses">Статусы</button>
            </div>

            <!-- Tab: Users -->
            <div class="tab-content active" id="tab-users">
                <div class="form-group">
                    <label>Пригласить пользователя</label>
                    <div class="input-row">
                        <input type="email" id="invite-user-email" class="form-input" placeholder="Email пользователя...">
                        <button class="btn btn-primary" id="invite-user-btn">Пригласить</button>
                    </div>
                    <div id="invite-user-message" class="form-message"></div>
                </div>
                <div class="form-group">
                    <label>Участники проекта</label>
                    <ul class="user-list" id="project-users-list">
                        <li class="user-list-empty">Загрузка...</li>
                    </ul>
                </div>
            </div>

            <!-- Tab: Rename -->
            <div class="tab-content" id="tab-rename">
                <div class="form-group">
                    <label>Новое название проекта</label>
                    <div class="input-row">
                        <input type="text" id="rename-project-input" class="form-input" placeholder="Введите название...">
                        <button class="btn btn-primary" id="rename-project-btn">Сохранить</button>
                    </div>
                    <div id="rename-project-message" class="form-message"></div>
                </div>
            </div>

            <!-- Tab: Statuses -->
            <div class="tab-content" id="tab-statuses">
                <div class="form-group">
                    <label>Добавить статус</label>
                    <div class="input-row">
                        <input type="text" id="settings-status-name-input" class="form-input" placeholder="Название статуса...">
                        <div id="settings-status-icon-picker"></div>
                        <button class="btn btn-primary" id="settings-add-status-btn">Добавить</button>
                    </div>
                    <div id="add-status-message" class="form-message"></div>
                </div>
                <div class="form-group">
                    <label>Текущие статусы</label>
                    <ul class="status-list" id="settings-statuses-list">
                        <li class="status-list-empty">Загрузка...</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" id="project-settings-modal-cancel">Закрыть</button>
        </div>
    </div>
</div>

{% include '_context_menus.html.twig' %}
{% endblock %}

{% block javascripts %}
{% include '_init_scripts.html.twig' %}
<script>
let pages = [];

// ==========================================
// Auth Check & Init
// ==========================================

document.addEventListener('DOMContentLoaded', function() {
    const token = localStorage.getItem('auth_token');
    if (!token) {
        window.location.href = '/login';
        return;
    }

    apiRequest('/me').then(function(response) {
        document.getElementById('user-name').textContent = response.user.name || response.user.email;
        loadProjects();
    }).catch(function() {
        localStorage.removeItem('auth_token');
        window.location.href = '/login';
    });

    document.getElementById('logout-btn').addEventListener('click', function() {
        localStorage.removeItem('auth_token');
        window.location.href = '/login';
    });

    document.getElementById('project-selector').addEventListener('change', function() {
        currentProjectId = parseInt(this.value);
        if (currentProjectId) {
            loadProjectUsers(currentProjectId);
            loadProjectStatuses(currentProjectId);
            loadMainPage();
        }
    });

    document.getElementById('new-page-btn').addEventListener('click', function() {
        showNewPageModal();
    });

    document.getElementById('new-page-modal-close').addEventListener('click', function() {
        closeNewPageModal();
    });

    document.getElementById('new-page-modal-cancel').addEventListener('click', function() {
        closeNewPageModal();
    });

    document.getElementById('new-page-modal-save').addEventListener('click', function() {
        confirmNewPage();
    });

    document.getElementById('new-page-title-input').addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            confirmNewPage();
        }
    });

    // Auto-save page title on input (delegated)
    document.addEventListener('input', function(e) {
        if (e.target.id === 'full-page-title') {
            var title = e.target.textContent.trim();
            var container = document.getElementById('tasks-container');
            var pageId = parseInt(container.dataset.pageId);
            if (title && pageId) {
                debouncedSave('page-title', function() {
                    apiRequest('/pages/' + pageId, 'PUT', { title: title });
                });
            }
        }
    });
});

// ==========================================
// Projects
// ==========================================

function loadProjects() {
    apiRequest('/projects').then(function(response) {
        var selector = document.getElementById('project-selector');
        selector.innerHTML = '';
        var defaultOption = document.createElement('option');
        defaultOption.value = '';
        defaultOption.textContent = 'Выберите проект...';
        selector.appendChild(defaultOption);

        response.projects.forEach(function(project) {
            var opt = document.createElement('option');
            opt.value = project.id;
            opt.textContent = project.name;
            selector.appendChild(opt);
        });

        if (response.currentProjectId) {
            selector.value = response.currentProjectId;
            currentProjectId = response.currentProjectId;
            loadProjectUsers(currentProjectId);
            loadMainPage();
        }
    }).catch(function(xhr) {
        console.error('Failed to load projects:', xhr);
    });
}

// ==========================================
// New Page
// ==========================================

function showNewPageModal() {
    if (!currentProjectId) return;
    document.getElementById('new-page-title-input').value = '';
    document.getElementById('new-page-modal').style.display = 'flex';
    setTimeout(function() {
        document.getElementById('new-page-title-input').focus();
    }, 100);
}

function closeNewPageModal() {
    document.getElementById('new-page-modal').style.display = 'none';
}

function confirmNewPage() {
    var title = document.getElementById('new-page-title-input').value.trim();
    if (!title) {
        document.getElementById('new-page-title-input').focus();
        return;
    }
    closeNewPageModal();
    apiRequest('/projects/' + currentProjectId + '/pages', 'POST', {
        title: title
    }).then(function(response) {
        window.location.href = '/page/' + response.page.id;
    }).catch(function(xhr) {
        console.error('Failed to create page:', xhr);
    });
}

// ==========================================
// Main Page - Pages Grid
// ==========================================

function loadMainPage() {
    if (!currentProjectId) return;

    loadProjectStatuses(currentProjectId);

    apiRequest('/projects/' + currentProjectId + '/pages').then(function(response) {
        pages = response.pages;
        renderPagesGrid();
    }).catch(function(xhr) {
        console.error('Failed to load pages:', xhr);
    });
}

function renderPagesGrid() {
    var grid = document.getElementById('pages-grid');
    grid.innerHTML = '';

    if (pages.length === 0) {
        grid.innerHTML = '<div class="empty-state"><i class="fas fa-file-alt fa-3x"></i><p>Нет страниц</p></div>';
        return;
    }

    var twoWeeksAgo = new Date();
    twoWeeksAgo.setDate(twoWeeksAgo.getDate() - 14);

    var expandedCount = 0;

    pages.forEach(function(page) {
        var dateStr = page.editedAt || page.createdAt;
        var editedAt = dateStr ? new Date(dateStr) : new Date();
        var isRecent = editedAt >= twoWeeksAgo;
        var shouldExpand = isRecent && expandedCount < 3;

        if (shouldExpand) expandedCount++;

        var card = document.createElement('div');
        card.className = 'page-card ' + (shouldExpand ? 'expanded' : 'collapsed');
        card.dataset.pageId = page.id;

        // Header with link to /page/{id}
        var header = document.createElement('div');
        header.className = 'page-card-header';

        var titleLink = document.createElement('a');
        titleLink.href = '/page/' + page.id;
        titleLink.className = 'page-card-title';
        titleLink.textContent = page.title;
        header.appendChild(titleLink);

        var headerRight = document.createElement('div');
        headerRight.className = 'page-card-header-right';

        var dateSpan = document.createElement('span');
        dateSpan.className = 'page-card-date';
        dateSpan.textContent = formatRelativeTime(dateStr);
        dateSpan.title = formatTooltipDate(dateStr);
        headerRight.appendChild(dateSpan);

        var burgerBtn = document.createElement('button');
        burgerBtn.className = 'burger-btn page-card-burger';
        burgerBtn.title = 'Настройки страницы';
        burgerBtn.innerHTML = '<i class="fas fa-bars"></i>';
        burgerBtn.dataset.pageId = page.id;
        burgerBtn.dataset.pageTitle = page.title;
        headerRight.appendChild(burgerBtn);

        header.appendChild(headerRight);

        card.appendChild(header);

        // Inline editor (only for expanded)
        if (shouldExpand) {
            var editorContainer = document.createElement('div');
            editorContainer.className = 'page-card-editor';
            card.appendChild(editorContainer);
            var pageTasks = (page.tasks || []).slice(0, 10);
            renderInlineTasks(pageTasks, editorContainer, page.id);
        }

        grid.appendChild(card);
    });

    // Make sure sortable is set up after all cards are in DOM
    makeSortable();
}

</script>
{% endblock %}