<!-- Context Menu: Statuses (on checkbox right-click) -->
<div class="context-menu" id="context-menu-status" style="display: none;">
    <ul class="context-menu-list">
    </ul>
</div>

<!-- Context Menu: Task actions (on text right-click) -->
<div class="context-menu" id="context-menu-task" style="display: none;">
    <ul class="context-menu-list">
    </ul>
</div>

<!-- Context Menu: Assignee (click on assignee name) -->
<div class="context-menu" id="context-menu-assignee" style="display: none;">
    <ul class="context-menu-list">
    </ul>
</div>

<!-- Context Menu: User name edit -->
<div class="context-menu" id="context-menu-username" style="display: none;">
    <div class="context-menu-username-body">
        <div class="form-group">
            <label>Имя пользователя</label>
            <input type="text" id="username-edit-input" class="form-input" placeholder="Введите имя..." autofocus>
        </div>
        <div class="context-menu-username-actions">
            <button class="btn btn-primary btn-sm" id="username-edit-save">Сохранить</button>
        </div>
    </div>
</div>

<!-- Burger Menu: Page Settings -->
<div class="context-menu" id="context-menu-page" style="display: none;">
    <div class="context-menu-page-body">
        <div class="form-group">
            <label>Название страницы</label>
            <input type="text" id="page-settings-title-input" class="form-input" placeholder="Введите название..." autofocus>
        </div>
        <div class="context-menu-page-actions">
            <button class="btn btn-primary btn-sm" id="page-settings-save">Сохранить</button>
            <button class="btn btn-danger btn-sm" id="page-settings-delete">Удалить</button>
        </div>
    </div>
</div>

<!-- New Status Modal -->
<div class="modal-overlay" id="new-status-modal" style="display: none;">
    <div class="modal modal-sm">
        <div class="modal-header">
            <h3>Новый статус</h3>
            <button class="modal-close" id="new-status-modal-close">&times;</button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label>Название статуса</label>
                <input type="text" id="new-status-name-input" class="form-input" placeholder="Например: В работе" autofocus>
            </div>
            <div class="form-group">
                <label>Иконка</label>
                <div id="new-status-icon-picker"></div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" id="new-status-modal-cancel">Отмена</button>
            <button class="btn btn-primary" id="new-status-modal-save">Создать</button>
        </div>
    </div>
</div>